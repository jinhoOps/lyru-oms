# Local development:
# 1. Copy this file to .env.local.
# 2. Fill in the public Supabase values below.
#
# GitHub Pages deployment:
# Add the same names under GitHub repository
# Settings > Secrets and variables > Actions > Variables.
#
# These are public browser values. Do not put the database password,
# service_role key, or any secret key in VITE_* env values.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key
